rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isApplicationOwner() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isApplicationOwner == true;
    }

    function tripDoc(tripId) {
      return firestore.get(/databases/(default)/documents/trips/$(tripId));
    }

    function tripExists(tripId) {
      return firestore.exists(/databases/(default)/documents/trips/$(tripId));
    }

    function isTripMember(tripId) {
      return isApplicationOwner()
        || (
          signedIn()
          && tripExists(tripId)
          && tripDoc(tripId).data.keys().hasAll(['memberUserIds'])
          && tripDoc(tripId).data.memberUserIds is list
          && request.auth.uid in tripDoc(tripId).data.memberUserIds
        );
    }

    function isTripOwner(tripId) {
      return signedIn()
        && tripExists(tripId)
        && tripDoc(tripId).data.ownerId == request.auth.uid;
    }

    function isValidChatImageUpload(tripId, ownerId, fileName) {
      return isTripMember(tripId)
        && ownerId == request.auth.uid
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        && fileName.matches('[A-Za-z0-9._-]+')
        && request.resource.metadata.authorId == request.auth.uid;
    }

    function isValidBannerFileName(fileName) {
      return fileName.matches('banner_[A-Za-z0-9._-]+');
    }

    // Legacy flat path — kept readable for existing messages.
    // Delete allowed once authorId metadata has been backfilled by the migration script.
    match /trips/{tripId}/messages/{fileName} {
      allow read: if isTripMember(tripId);
      allow delete: if isTripMember(tripId)
        && resource.metadata.keys().hasAny(['authorId'])
        && resource.metadata['authorId'] == request.auth.uid;
    }

    // Chat image attachments: trips/{tripId}/messages/{authorUid}/<messageId>.<ext>
    match /trips/{tripId}/messages/{ownerId}/{fileName} {
      allow read: if isTripMember(tripId);
      allow create, update: if isValidChatImageUpload(tripId, ownerId, fileName);
      allow delete: if isTripMember(tripId)
        && ownerId == request.auth.uid;
    }

    // Banner assets are stored under:
    // trips/{tripId}/banner_<timestamp>.<ext>
    match /trips/{tripId}/{fileName} {
      allow write: if isTripOwner(tripId)
        && isValidBannerFileName(fileName);
    }

    match /trips/{tripId}/{allPaths=**} {
      allow read: if isTripMember(tripId);
      allow write: if false;
    }

    // Profile assets are stored under:
    // users/{uid}/profile_<timestamp>.<ext>
    match /users/{uid}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Self-managed preview release metadata + APK (see RELEASE.md / preview publishing).
    match /versions/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
