rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function tripDoc(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId));
    }

    function isTripMember(tripId) {
      return signedIn()
        && tripDoc(tripId).data.keys().hasAll(['memberIds'])
        && tripDoc(tripId).data.memberIds is list
        && request.auth.uid in tripDoc(tripId).data.memberIds;
    }

    function isTripMemberAfterWrite(tripId) {
      return signedIn()
        && existsAfter(/databases/$(database)/documents/trips/$(tripId))
        && getAfter(/databases/$(database)/documents/trips/$(tripId))
          .data.keys().hasAll(['memberIds'])
        && getAfter(/databases/$(database)/documents/trips/$(tripId))
          .data.memberIds is list
        && request.auth.uid in getAfter(
          /databases/$(database)/documents/trips/$(tripId)
        ).data.memberIds;
    }

    function isTripAdmin(tripId) {
      return isTripMember(tripId)
        && (
          tripDoc(tripId).data.ownerId == request.auth.uid
          || (
            tripDoc(tripId).data.adminMemberIds is list
            && request.auth.uid in tripDoc(tripId).data.adminMemberIds
          )
        );
    }

    function tripCallerRoleRank(tripId) {
      return tripDoc(tripId).data.ownerId == request.auth.uid
        ? 2
        : (
            tripDoc(tripId).data.adminMemberIds is list
            && request.auth.uid in tripDoc(tripId).data.adminMemberIds
          )
          ? 1
          : 0;
    }

    function roleRank(roleName) {
      return roleName == 'owner'
        ? 2
        : roleName == 'admin'
          ? 1
          : 0;
    }

    function tripEditGeneralInfoMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.editGeneralInfo is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.editGeneralInfo
        : 'admin';
    }

    function tripManageBannerMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.manageBanner is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.manageBanner
        : 'admin';
    }

    function canEditTripGeneralInfo(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripEditGeneralInfoMinRole(tripId));
    }

    function canManageTripBanner(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripManageBannerMinRole(tripId));
    }

    function activityLocked(data) {
      return data.keys().hasAny(['isLocked']) && data.isLocked == true;
    }

    function canReadTrip(data) {
      return signedIn()
        && (
          (data.ownerId is string && data.ownerId == request.auth.uid)
          || (data.memberIds is list && request.auth.uid in data.memberIds)
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;

      match /fcmTokens/{tokenDocId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /tripNotificationCounters/{tripId} {
        allow read: if signedIn() && request.auth.uid == userId;
      }

      match /tripNotificationPresence/{tripId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /cupidonMatches/{matchId} {
        allow read, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /trips/{tripId} {
      // Query used by trips list: where('memberIds', arrayContains: uid).
      allow list: if signedIn()
        && request.auth.uid in resource.data.memberIds;
      // Direct doc read (by id): creator or participant.
      allow get: if canReadTrip(resource.data);

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds;

      allow update: if signedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (
          canManageTripBanner(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'bannerImageUrl',
            'bannerImagePath',
            'bannerUpdatedAt',
          ])
        ) ||
        (
          canEditTripGeneralInfo(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title',
            'destination',
            'address',
            'linkUrl',
            'startDate',
            'endDate',
          ])
        ) ||
        (
          request.auth.uid in resource.data.memberIds &&
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberPublicLabels.' + request.auth.uid])
            || (
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['memberPublicLabels'])
              && request.resource.data.memberPublicLabels is map
              && resource.data.memberPublicLabels is map
              && request.resource.data.memberPublicLabels
                .diff(resource.data.memberPublicLabels).affectedKeys()
                .hasOnly([request.auth.uid])
            )
          )
        )
      );

      allow delete: if signedIn()
        && resource.data.ownerId == request.auth.uid;

      match /expenseGroups/{groupId} {
        allow read, update, delete: if isTripMember(tripId);
        allow create: if isTripMember(tripId) || isTripMemberAfterWrite(tripId);
      }

      match /expenses/{expenseId} {
        allow read, write: if isTripMember(tripId);
      }

      match /expenseSettledTransfers/{transferId} {
        allow read, write: if isTripMember(tripId);
      }

      match /rooms/{roomId} {
        allow read, write: if isTripMember(tripId);
      }

      match /activities/{activityId} {
        allow read: if isTripMember(tripId);
        allow create: if isTripMember(tripId);
        allow update, delete: if isTripMember(tripId)
          && (
            !activityLocked(resource.data)
            || isTripAdmin(tripId)
          );
      }

      match /shoppingItems/{itemId} {
        allow read, write: if isTripMember(tripId);
      }

      match /meals/{mealId} {
        allow read, write: if isTripMember(tripId);
      }

      match /messages/{messageId} {
        allow read: if isTripMember(tripId);
        allow create: if isTripMember(tripId)
          && request.resource.data.keys().hasOnly(['text', 'authorId', 'createdAt'])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000;
        allow update: if isTripMember(tripId)
          && (
            (
              resource.data.authorId == request.auth.uid
              && request.resource.data.authorId == resource.data.authorId
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 4000
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'updatedAt'])
            )
            || (
              request.resource.data.authorId == resource.data.authorId
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.text == resource.data.text
              && request.resource.data.reactionsByUser is map
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly([
                  'reactionsByUser',
                  'reactionsByUser.' + request.auth.uid,
                  'updatedAt',
                ])
            )
          );
        allow delete: if isTripMember(tripId)
          && resource.data.authorId == request.auth.uid;

        match /reactions/{userId} {
          allow read: if isTripMember(tripId);
          allow create, update: if isTripMember(tripId)
            && userId == request.auth.uid
            && request.resource.data.keys().hasOnly(['emoji', 'createdAt', 'updatedAt'])
            && request.resource.data.emoji is string
            && request.resource.data.emoji.size() > 0
            && request.resource.data.emoji.size() <= 16;
          allow delete: if isTripMember(tripId)
            && userId == request.auth.uid;
        }
      }

      match /notificationReads/{userId} {
        allow read: if isTripMember(tripId)
          && userId == request.auth.uid;
        allow create, update: if isTripMember(tripId)
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(['channels', 'updatedAt'])
          && request.resource.data.channels is map;
      }

      /// Per-member trip data (presence bounds, etc.).
      match /members/{memberId} {
        allow read: if isTripMember(tripId);
        allow create, update: if isTripMember(tripId)
          && memberId == request.auth.uid;
        allow delete: if false;
      }

      match /cupidonLikes/{likeId} {
        allow read: if isTripMember(tripId);
      }
    }

    // Written exclusively by Cloud Functions (Admin SDK). Clients have no access.
    match /notificationQueue/{notifId} {
      allow read, write: if false;
    }
  }
}
