rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function tripDoc(tripId) {
      return get(/databases/$(database)/documents/trips/$(tripId));
    }

    function isTripMember(tripId) {
      return signedIn()
        && tripDoc(tripId).data.keys().hasAll(['memberIds'])
        && tripDoc(tripId).data.memberIds is list
        && request.auth.uid in tripDoc(tripId).data.memberIds;
    }

    function tripCallerRoleRank(tripId) {
      return tripDoc(tripId).data.ownerId == request.auth.uid
        ? 2
        : (
            tripDoc(tripId).data.adminMemberIds is list
            && request.auth.uid in tripDoc(tripId).data.adminMemberIds
          )
          ? 1
          : 0;
    }

    function roleRank(roleName) {
      return roleName == 'owner'
        ? 2
        : roleName == 'admin'
          ? 1
          : 0;
    }

    function tripEditGeneralInfoMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.editGeneralInfo is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.editGeneralInfo
        : 'admin';
    }

    function tripManageBannerMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.manageBanner is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.manageBanner
        : 'admin';
    }

    function tripShareAccessMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.shareAccess is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.shareAccess
        : 'participant';
    }

    function tripPublishAnnouncementsMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.publishAnnouncements is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.publishAnnouncements
        : 'admin';
    }

    function canEditTripGeneralInfo(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripEditGeneralInfoMinRole(tripId));
    }

    function canManageTripBanner(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripManageBannerMinRole(tripId));
    }

    function canShareTripAccess(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripShareAccessMinRole(tripId));
    }

    function canPublishTripAnnouncements(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripPublishAnnouncementsMinRole(tripId));
    }

    function tripManageTripSettingsMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.tripGeneral is map
          && tripDoc(tripId).data.permissions.tripGeneral.manageTripSettings is string
        )
        ? tripDoc(tripId).data.permissions.tripGeneral.manageTripSettings
        : 'owner';
    }

    function canManageTripSettings(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripManageTripSettingsMinRole(tripId));
    }

    function tripExpenseCreatePostMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.expenses is map
          && tripDoc(tripId).data.permissions.expenses.createExpensePost is string
        )
        ? tripDoc(tripId).data.permissions.expenses.createExpensePost
        : 'participant';
    }

    function tripExpenseEditPostMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.expenses is map
          && tripDoc(tripId).data.permissions.expenses.editExpensePost is string
        )
        ? tripDoc(tripId).data.permissions.expenses.editExpensePost
        : 'participant';
    }

    function tripExpenseDeletePostMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.expenses is map
          && tripDoc(tripId).data.permissions.expenses.deleteExpensePost is string
        )
        ? tripDoc(tripId).data.permissions.expenses.deleteExpensePost
        : 'participant';
    }

    function canCreateExpensePost(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripExpenseCreatePostMinRole(tripId));
    }

    function canEditExpensePost(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripExpenseEditPostMinRole(tripId));
    }

    function canDeleteExpensePost(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripExpenseDeletePostMinRole(tripId));
    }

    function tripSuggestActivityMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.activities is map
          && tripDoc(tripId).data.permissions.activities.suggestActivity is string
        )
        ? tripDoc(tripId).data.permissions.activities.suggestActivity
        : 'participant';
    }

    function canSuggestActivity(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripSuggestActivityMinRole(tripId));
    }

    function tripPlanActivityMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.activities is map
          && tripDoc(tripId).data.permissions.activities.planActivity is string
        )
        ? tripDoc(tripId).data.permissions.activities.planActivity
        : 'admin';
    }

    function canPlanActivity(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripPlanActivityMinRole(tripId));
    }

    function tripEditActivityMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.activities is map
          && tripDoc(tripId).data.permissions.activities.editActivity is string
        )
        ? tripDoc(tripId).data.permissions.activities.editActivity
        : 'participant';
    }

    function canEditActivity(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripEditActivityMinRole(tripId));
    }

    function tripDeleteActivityMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.activities is map
          && tripDoc(tripId).data.permissions.activities.deleteActivity is string
        )
        ? tripDoc(tripId).data.permissions.activities.deleteActivity
        : 'participant';
    }

    function canDeleteActivity(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripDeleteActivityMinRole(tripId));
    }

    function tripDeleteCheckedShoppingItemsMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.shopping is map
          && tripDoc(tripId).data.permissions.shopping.deleteCheckedItems is string
        )
        ? tripDoc(tripId).data.permissions.shopping.deleteCheckedItems
        : 'admin';
    }

    function canDeleteCheckedShoppingItems(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripDeleteCheckedShoppingItemsMinRole(tripId));
    }

    function tripCreateParticipantMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.participants is map
          && tripDoc(tripId).data.permissions.participants.createParticipant is string
        )
        ? tripDoc(tripId).data.permissions.participants.createParticipant
        : 'owner';
    }

    function canCreateTripParticipant(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripCreateParticipantMinRole(tripId));
    }

    function tripEditPlaceholderParticipantMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.participants is map
          && tripDoc(tripId).data.permissions.participants.editPlaceholderParticipant is string
        )
        ? tripDoc(tripId).data.permissions.participants.editPlaceholderParticipant
        : 'owner';
    }

    function canEditTripPlaceholderParticipant(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripEditPlaceholderParticipantMinRole(tripId));
    }

    function tripDeleteRegisteredParticipantMinRole(tripId) {
      return (
          tripDoc(tripId).data.permissions is map
          && tripDoc(tripId).data.permissions.participants is map
          && tripDoc(tripId).data.permissions.participants.deleteRegisteredParticipant is string
        )
        ? tripDoc(tripId).data.permissions.participants.deleteRegisteredParticipant
        : 'owner';
    }

    function canDeleteTripRegisteredParticipant(tripId) {
      return isTripMember(tripId)
        && tripCallerRoleRank(tripId) >= roleRank(tripDeleteRegisteredParticipantMinRole(tripId));
    }

    function canReadTrip(data) {
      return signedIn()
        && (
          (data.ownerId is string && data.ownerId == request.auth.uid)
          || (data.memberIds is list && request.auth.uid in data.memberIds)
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;

      match /fcmTokens/{tokenDocId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /tripNotificationCounters/{tripId} {
        allow read: if signedIn() && request.auth.uid == userId;
      }

      match /tripNotificationPresence/{tripId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /cupidonMatches/{matchId} {
        allow read, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /trips/{tripId} {
      // Query used by trips list: where('memberIds', arrayContains: uid).
      allow list: if signedIn()
        && request.auth.uid in resource.data.memberIds;
      // Direct doc read (by id): creator or participant.
      allow get: if canReadTrip(resource.data);

      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds;

      allow update: if signedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (
          canManageTripBanner(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'bannerImageUrl',
            'bannerImagePath',
            'bannerUpdatedAt',
          ])
        ) ||
        (
          canShareTripAccess(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'inviteToken',
          ])
        ) ||
        (
          canEditTripGeneralInfo(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title',
            'destination',
            'address',
            'linkUrl',
            'startDate',
            'endDate',
          ])
        ) ||
        (
          canCreateTripParticipant(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'memberIds',
            'memberPublicLabels',
          ])
        ) ||
        (
          canEditTripPlaceholderParticipant(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'memberPublicLabels',
          ])
        ) ||
        (
          canDeleteTripRegisteredParticipant(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'memberIds',
            'memberPublicLabels',
            'adminMemberIds',
          ])
        ) ||
        (
          request.auth.uid in resource.data.memberIds &&
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberPublicLabels.' + request.auth.uid])
            || (
              request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['memberPublicLabels'])
              && request.resource.data.memberPublicLabels is map
              && resource.data.memberPublicLabels is map
              && request.resource.data.memberPublicLabels
                .diff(resource.data.memberPublicLabels).affectedKeys()
                .hasOnly([request.auth.uid])
            )
          )
        ) ||
        (
          canManageTripSettings(tripId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'permissions',
          ])
        )
      );

      allow delete: if signedIn()
        && resource.data.ownerId == request.auth.uid;

      match /expenseGroups/{groupId} {
        allow read: if isTripMember(tripId);
        allow create: if canCreateExpensePost(tripId)
          && request.auth.uid in request.resource.data.visibleToMemberIds
          && request.resource.data.visibleToMemberIds is list;
        allow update: if canEditExpensePost(tripId)
          && request.auth.uid in resource.data.visibleToMemberIds
          && resource.data.visibleToMemberIds is list
          && request.resource.data.visibleToMemberIds is list;
        allow delete: if canDeleteExpensePost(tripId)
          && request.auth.uid in resource.data.visibleToMemberIds
          && resource.data.visibleToMemberIds is list;
      }

      match /expenses/{expenseId} {
        allow read, write: if isTripMember(tripId);
      }

      match /expenseSettledTransfers/{transferId} {
        allow read, write: if isTripMember(tripId);
      }

      match /rooms/{roomId} {
        allow read, write: if isTripMember(tripId);
      }

      match /activities/{activityId} {
        allow read: if isTripMember(tripId);
        allow create: if canSuggestActivity(tripId);
        allow update: if (
          canPlanActivity(tripId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['plannedAt', 'updatedAt'])
        ) || (
          canEditActivity(tripId)
          && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['plannedAt'])
        );
        allow delete: if canDeleteActivity(tripId);
      }

      match /shoppingItems/{itemId} {
        allow read, create, update: if isTripMember(tripId);
        allow delete: if isTripMember(tripId)
          && (
            !(resource.data.checked is bool && resource.data.checked)
            || canDeleteCheckedShoppingItems(tripId)
          );
      }

      match /meals/{mealId} {
        allow read, write: if isTripMember(tripId);
      }

      match /messages/{messageId} {
        allow read: if isTripMember(tripId);
        allow create: if isTripMember(tripId)
          && request.resource.data.keys().hasOnly(['text', 'authorId', 'createdAt'])
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 4000;
        allow update: if isTripMember(tripId)
          && (
            (
              resource.data.authorId == request.auth.uid
              && request.resource.data.authorId == resource.data.authorId
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 4000
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['text', 'updatedAt'])
            )
            || (
              request.resource.data.authorId == resource.data.authorId
              && request.resource.data.createdAt == resource.data.createdAt
              && request.resource.data.text == resource.data.text
              && request.resource.data.reactionsByUser is map
              && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly([
                  'reactionsByUser',
                  'reactionsByUser.' + request.auth.uid,
                  'updatedAt',
                ])
            )
          );
        allow delete: if isTripMember(tripId)
          && resource.data.authorId == request.auth.uid;

        match /reactions/{userId} {
          allow read: if isTripMember(tripId);
          allow create, update: if isTripMember(tripId)
            && userId == request.auth.uid
            && request.resource.data.keys().hasOnly(['emoji', 'createdAt', 'updatedAt'])
            && request.resource.data.emoji is string
            && request.resource.data.emoji.size() > 0
            && request.resource.data.emoji.size() <= 16;
          allow delete: if isTripMember(tripId)
            && userId == request.auth.uid;
        }
      }

      match /announcements/{announcementId} {
        allow read: if isTripMember(tripId);
        allow create: if canPublishTripAnnouncements(tripId);
        allow update, delete: if canPublishTripAnnouncements(tripId);
      }

      match /notificationReads/{userId} {
        allow read: if isTripMember(tripId)
          && userId == request.auth.uid;
        allow create, update: if isTripMember(tripId)
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(['channels', 'updatedAt'])
          && request.resource.data.channels is map;
      }

      /// Per-member trip data (presence bounds, etc.).
      match /members/{memberId} {
        allow read: if isTripMember(tripId);
        allow create, update: if isTripMember(tripId)
          && memberId == request.auth.uid;
        allow delete: if false;
      }

      match /cupidonLikes/{likeId} {
        allow read: if isTripMember(tripId);
      }
    }

    // Written exclusively by Cloud Functions (Admin SDK). Clients have no access.
    match /notificationQueue/{notifId} {
      allow read, write: if false;
    }
  }
}
